#!/bin/bash
set -euo pipefail

# ─── Config ───────────────────────────────────────────────────────────
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zen-sync"
CONFIG_FILE="$CONFIG_DIR/config"

# ─── Colors & UI ─────────────────────────────────────────────────────
R="\033[0m"
B="\033[1m"
D="\033[2m"
PURPLE="\033[38;2;147;130;220m"
GREEN="\033[38;2;130;200;160m"
RED="\033[38;2;210;100;120m"
YELLOW="\033[38;2;220;180;100m"
GRAY="\033[38;2;100;100;110m"
WHITE="\033[38;2;200;200;210m"

die()  { printf "${RED}${B} error${R} ${WHITE}%s${R}\n" "$*" >&2; exit 1; }
info() { printf "${PURPLE}${B}  %s${R}\n" "$*"; }
ok()   { printf "${GREEN}  ✓${R} ${WHITE}%s${R}\n" "$*"; }
fail() { printf "${RED}  ✗${R} ${WHITE}%s${R}\n" "$*" >&2; }
step() { printf "${PURPLE}%s${R} ${D}%s${R}\n" "$1" "$2"; }
dim()  { printf "${GRAY}%s${R}\n" "$*"; }

header() {
    local label="zen-sync $1"
    local inner=33
    local pad=$(( (inner - ${#label}) / 2 ))
    local rpad=$(( inner - ${#label} - pad ))
    printf "\n"
    printf "${PURPLE}${B}  ╭─────────────────────────────────╮${R}\n"
    printf "${PURPLE}${B}  │${R}${B}%*s%s%*s${PURPLE}${B}│${R}\n" "$((pad))" "" "$label" "$((rpad))" ""
    printf "${PURPLE}${B}  ╰─────────────────────────────────╯${R}\n"
    printf "\n"
}

usage() {
    header "help"
    printf "${B}  Usage:${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}push${R}              ${D}Push session to remote${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}pull${R}              ${D}Pull session from remote${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}merge${R}             ${D}Merge remote tabs into local${R}\n"
    printf "    ${WHITE}zen-sync${R} ${GREEN}push --restart${R}    ${D}Close Zen, sync, reopen${R}\n"
    printf "    ${WHITE}zen-sync${R} ${YELLOW}status${R}            ${D}Compare both devices${R}\n"
    printf "    ${WHITE}zen-sync${R} ${YELLOW}init${R}              ${D}Setup wizard${R}\n"
    printf "\n"
    printf "  ${D}Modes: ssh (direct device-to-device) or r2 (Cloudflare R2 cloud)${R}\n"
    printf "  ${D}Config: %s${R}\n" "$CONFIG_DIR/config"
    printf "\n"
    exit 0
}

# ─── Zen process management ──────────────────────────────────────────
zen_close_remote() {
    local remote="$1"
    if ssh "$remote" 'pgrep -x zen-bin >/dev/null 2>&1'; then
        step "  ◼" "Closing Zen on remote..."
        ssh -o ConnectTimeout=5 "$remote" 'kill -SIGTERM $(pgrep -x zen-bin | head -1) 2>/dev/null; exit 0' || true
        sleep 5
    fi
}

zen_open_remote() {
    local remote="$1"
    step "  ▶" "Reopening Zen on remote..."
    ssh "$remote" 'WAYLAND_DISPLAY=wayland-1 DISPLAY=:0 XDG_RUNTIME_DIR=/run/user/$(id -u) nohup zen-browser >/dev/null 2>&1 </dev/null &; exit 0' || true
}

zen_close_local() {
    local pids
    pids=$(pgrep -x zen-bin 2>/dev/null || true)
    if [[ -n "$pids" ]]; then
        step "  ◼" "Closing Zen locally..."
        kill -SIGTERM $(echo "$pids" | head -1) 2>/dev/null || true
        sleep 3
    fi
}

zen_open_local() {
    step "  ▶" "Reopening Zen locally..."
    nohup zen-browser >/dev/null 2>&1 &
}

# ─── Resolve script directory ────────────────────────────────────────
resolve_script_dir() {
    local dir
    dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    # Follow symlink if needed
    if [[ -L "${BASH_SOURCE[0]}" ]]; then
        dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
    fi
    echo "$dir"
}

SCRIPT_DIR="$(resolve_script_dir)"

find_py() {
    local name="$1"
    local path="$SCRIPT_DIR/$name"
    [[ -f "$path" ]] && { echo "$path"; return; }
    path="$HOME/.local/lib/zen-sync/$name"
    [[ -f "$path" ]] && { echo "$path"; return; }
    die "$name not found. Re-run install."
}

# ─── Config management ────────────────────────────────────────────────
load_config() {
    [[ -f "$CONFIG_FILE" ]] || die "not configured. Run 'zen-sync init' first."
    source "$CONFIG_FILE"
    : "${MODE:?}" "${LOCAL_PROFILE:?}"

    if [[ "$MODE" == "ssh" ]]; then
        : "${REMOTE_HOST:?}" "${REMOTE_USER:?}" "${REMOTE_PROFILE:?}"
    elif [[ "$MODE" == "r2" ]]; then
        : "${R2_ACCOUNT_ID:?}" "${R2_ACCESS_KEY:?}" "${R2_SECRET_KEY:?}" "${R2_BUCKET:?}"
        if [[ "${AGE_MODE:-keyfile}" == "keyfile" ]]; then
            : "${AGE_KEY_PATH:?}"
        fi
    else
        die "unknown mode: $MODE"
    fi
}

cloud_config_json() {
    printf '{"account_id":"%s","access_key":"%s","secret_key":"%s","bucket":"%s","age_key_path":"%s","age_mode":"%s","config_dir":"%s","profile":"%s"}' \
        "$R2_ACCOUNT_ID" "$R2_ACCESS_KEY" "$R2_SECRET_KEY" "$R2_BUCKET" "${AGE_KEY_PATH:-}" "${AGE_MODE:-keyfile}" "$CONFIG_DIR" "$LOCAL_PROFILE"
}

find_zen_dir() {
    local candidates=("$HOME/.config/zen" "$HOME/.zen")
    for d in "${candidates[@]}"; do
        [[ -d "$d" ]] && { echo "$d"; return; }
    done
    die "Zen Browser not found (tried ~/.config/zen and ~/.zen)"
}

find_local_profile() {
    local zen_dir
    zen_dir=$(find_zen_dir)

    local profiles=()
    while IFS= read -r d; do
        [[ -f "$d/zen-sessions.jsonlz4" ]] && profiles+=("$d")
    done < <(find "$zen_dir" -maxdepth 1 -type d -name "*.Default (release)" 2>/dev/null)

    if [[ ${#profiles[@]} -eq 0 ]]; then
        while IFS= read -r d; do
            [[ -f "$d/zen-sessions.jsonlz4" ]] && profiles+=("$d")
        done < <(find "$zen_dir" -maxdepth 1 -type d 2>/dev/null)
    fi

    [[ ${#profiles[@]} -gt 0 ]] || die "no Zen profile found with zen-sessions.jsonlz4"

    if [[ ${#profiles[@]} -eq 1 ]]; then
        echo "${profiles[0]}"
    else
        echo "Multiple profiles found:" >&2
        for i in "${!profiles[@]}"; do
            echo "  [$i] ${profiles[$i]}" >&2
        done
        read -rp "Select profile [0]: " choice
        echo "${profiles[${choice:-0}]}"
    fi
}

# ─── Init ─────────────────────────────────────────────────────────────
prompt() {
    local label="$1" default="${2:-}"
    if [[ -n "$default" ]]; then
        printf "  ${PURPLE}›${R} ${WHITE}%s${R} ${D}[%s]${R} " "$label" "$default"
    else
        printf "  ${PURPLE}›${R} ${WHITE}%s${R} " "$label"
    fi
}

secret_prompt() {
    local label="$1"
    printf "  ${PURPLE}›${R} ${WHITE}%s${R} " "$label"
    read -rs val
    printf "\n"
    echo "$val"
}

cmd_init() {
    mkdir -p "$CONFIG_DIR"
    header "init"

    printf "  ${WHITE}Choose sync mode:${R}\n\n"
    printf "    ${PURPLE}❯${R} ${GREEN}1${R}  ${B}SSH${R}   ${D}Direct device-to-device (same network)${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}2${R}  ${B}R2${R}    ${D}Cloudflare R2 cloud (works anywhere)${R}\n"
    printf "\n"
    prompt "Mode" "1"
    read -r mode_choice
    local mode="ssh"
    [[ "$mode_choice" == "2" ]] && mode="r2"

    printf "\n"

    # Find local profile
    step "  ⟳" "Finding local profile..."
    local local_profile
    local_profile=$(find_local_profile)
    ok "Local: $(basename "$local_profile")"

    printf "\n"

    if [[ "$mode" == "ssh" ]]; then
        init_ssh "$local_profile"
    else
        init_r2 "$local_profile"
    fi
}

init_ssh() {
    local local_profile="$1"

    prompt "Remote host (IP or hostname)"; read -r host
    prompt "Remote user" "$USER"; read -r user
    user="${user:-$USER}"

    printf "\n"
    step "  ⟳" "Testing SSH..."
    ssh -o ConnectTimeout=5 "$user@$host" "echo ok" >/dev/null 2>&1 \
        || die "cannot connect to $user@$host"
    ok "SSH connected"

    step "  ⟳" "Finding remote profile..."
    local remote_profile
    remote_profile=$(ssh "$user@$host" 'for d in ~/.config/zen ~/.zen; do [[ -d "$d" ]] && { find "$d" -maxdepth 1 -type d -name "*.Default (release)" 2>/dev/null | head -1; break; }; done')
    [[ -n "$remote_profile" ]] || die "no Zen profile found on remote"
    ok "Remote: $(basename "$remote_profile")"

    cat > "$CONFIG_FILE" <<CONF
MODE="ssh"
REMOTE_HOST="$host"
REMOTE_USER="$user"
LOCAL_PROFILE="$local_profile"
REMOTE_PROFILE="$remote_profile"
CONF

    printf "\n"
    printf "  ${GREEN}${B}✓ Config saved${R} ${D}(SSH mode)${R}\n"
    dim "  Use 'zen-sync push' or 'zen-sync pull' to start syncing"
    printf "\n"
}

init_r2() {
    local local_profile="$1"

    command -v age >/dev/null 2>&1 || die "age not installed. Install it first (e.g. sudo pacman -S age)"

    prompt "Cloudflare Account ID"; read -r account_id
    prompt "R2 Access Key ID"; read -r access_key
    prompt "R2 Secret Access Key"; read -r secret_key
    prompt "R2 Bucket name"; read -r bucket

    # Test connection
    printf "\n"
    step "  ⟳" "Testing R2 connection..."
    local cloud_py
    cloud_py=$(find_py "cloud.py")
    local test_config
    test_config=$(printf '{"account_id":"%s","access_key":"%s","secret_key":"%s","bucket":"%s"}' \
        "$account_id" "$access_key" "$secret_key" "$bucket")
    if python3 "$cloud_py" test "$test_config" >/dev/null 2>&1; then
        ok "R2 connected"
    else
        die "could not connect to R2. Check your credentials and bucket name."
    fi

    # Encryption setup
    printf "\n"
    printf "  ${WHITE}Encryption method:${R}\n\n"
    printf "    ${PURPLE}❯${R} ${GREEN}1${R}  ${B}Passphrase${R}   ${D}Same passphrase on all devices (recommended)${R}\n"
    printf "    ${PURPLE}❯${R} ${GREEN}2${R}  ${B}Key file${R}     ${D}Generate key, copy to other devices${R}\n"
    printf "\n"
    prompt "Encryption" "1"; read -r enc_choice
    local enc_mode="passphrase"
    [[ "$enc_choice" == "2" ]] && enc_mode="keyfile"

    local age_key="$CONFIG_DIR/age-key.txt"
    printf "\n"

    if [[ "$enc_mode" == "passphrase" ]]; then
        local passphrase
        printf "  ${PURPLE}›${R} ${WHITE}Passphrase${R} ${D}(hidden, use the same on all devices)${R} "
        read -rs passphrase
        printf "\n"
        echo "$passphrase" > "$CONFIG_DIR/passphrase"
        chmod 600 "$CONFIG_DIR/passphrase"
        ok "Passphrase saved"
        dim "  Use the same passphrase when setting up other devices"

        cat > "$CONFIG_FILE" <<CONF
MODE="r2"
R2_ACCOUNT_ID="$account_id"
R2_ACCESS_KEY="$access_key"
R2_SECRET_KEY="$secret_key"
R2_BUCKET="$bucket"
AGE_MODE="passphrase"
LOCAL_PROFILE="$local_profile"
CONF
    else
        if [[ -f "$age_key" ]]; then
            ok "Using existing age key"
            printf "  ${YELLOW}Make sure this key is on all devices:${R}\n"
            dim "  scp $age_key user@host:$age_key"
        else
            step "  🔑" "Generating age encryption key..."
            age-keygen -o "$age_key" 2>/dev/null
            chmod 600 "$age_key"
            ok "Key saved to $age_key"
            printf "\n"
            printf "  ${YELLOW}Copy this key to your other device:${R}\n"
            dim "  scp $age_key user@host:$age_key"
        fi

        cat > "$CONFIG_FILE" <<CONF
MODE="r2"
R2_ACCOUNT_ID="$account_id"
R2_ACCESS_KEY="$access_key"
R2_SECRET_KEY="$secret_key"
R2_BUCKET="$bucket"
AGE_MODE="keyfile"
AGE_KEY_PATH="$age_key"
LOCAL_PROFILE="$local_profile"
CONF
    fi
    chmod 600 "$CONFIG_FILE"

    printf "\n"
    printf "  ${GREEN}${B}✓ Config saved${R} ${D}(R2 mode)${R}\n"
    dim "  Use 'zen-sync push' or 'zen-sync pull' to start syncing"
    printf "\n"
}

# ─── Sync files list ─────────────────────────────────────────────────
SYNC_FILES=(
    "zen-sessions.jsonlz4"
    "zen-sessions-backup/clean.jsonlz4"
    "sessionstore-backups/recovery.jsonlz4"
    "sessionstore-backups/recovery.baklz4"
    "sessionstore-backups/previous.jsonlz4"
    "prefs.js"
    "containers.json"
)

# ─── Push ─────────────────────────────────────────────────────────────
cmd_push() {
    load_config
    local restart=false
    for arg in "$@"; do
        [[ "$arg" == "--restart" ]] && restart=true
    done

    if [[ "$MODE" == "ssh" ]]; then
        push_ssh "$restart"
    else
        push_r2 "$restart"
    fi
}

push_ssh() {
    local restart=$1
    local remote="$REMOTE_USER@$REMOTE_HOST"

    header "push"
    printf "  ${D}local${R} ${PURPLE}→${R} ${WHITE}${B}%s${R}\n\n" "$REMOTE_HOST"

    [[ "$restart" == "true" ]] && zen_close_remote "$remote"

    for f in "${SYNC_FILES[@]}"; do
        local src="$LOCAL_PROFILE/$f"
        if [[ -f "$src" ]]; then
            if scp -q "$src" "$remote:$REMOTE_PROFILE/$f" 2>/dev/null; then
                ok "$f"
            else
                fail "$f"
            fi
        fi
    done

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_remote "$remote"

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

push_r2() {
    local restart=$1

    header "push"
    printf "  ${D}local${R} ${PURPLE}→${R} ${WHITE}${B}R2 cloud${R}\n\n"

    step "  ↑" "Encrypting and uploading..."
    local cloud_py
    cloud_py=$(find_py "cloud.py")
    local result
    result=$(python3 "$cloud_py" push "$(cloud_config_json)") || die "upload failed"

    local raw_size enc_size
    raw_size=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['raw_size'])")
    enc_size=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['encrypted_size'])")

    ok "Uploaded $(numfmt --to=iec "$raw_size") (encrypted: $(numfmt --to=iec "$enc_size"))"

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

# ─── Pull ─────────────────────────────────────────────────────────────
cmd_pull() {
    load_config
    local restart=false
    for arg in "$@"; do
        [[ "$arg" == "--restart" ]] && restart=true
    done

    if [[ "$MODE" == "ssh" ]]; then
        pull_ssh "$restart"
    else
        pull_r2 "$restart"
    fi
}

pull_ssh() {
    local restart=$1
    local remote="$REMOTE_USER@$REMOTE_HOST"

    header "pull"
    printf "  ${WHITE}${B}%s${R} ${PURPLE}←${R} ${D}local${R}\n\n" "$REMOTE_HOST"

    [[ "$restart" == "true" ]] && zen_close_local

    for f in "${SYNC_FILES[@]}"; do
        local dst="$LOCAL_PROFILE/$f"
        if scp -q "$remote:$REMOTE_PROFILE/$f" "$dst" 2>/dev/null; then
            ok "$f"
        else
            fail "$f (not found)"
        fi
    done

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_local

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

pull_r2() {
    local restart=$1

    header "pull"
    printf "  ${WHITE}${B}R2 cloud${R} ${PURPLE}←${R} ${D}local${R}\n\n"

    [[ "$restart" == "true" ]] && zen_close_local

    step "  ↓" "Downloading and decrypting..."
    local cloud_py
    cloud_py=$(find_py "cloud.py")
    local result
    result=$(python3 "$cloud_py" pull "$(cloud_config_json)") || die "download failed"

    local error
    error=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('error',''))" 2>/dev/null)
    if [[ -n "$error" ]]; then
        die "$error"
    fi

    local size
    size=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['size'])")
    ok "Downloaded $(numfmt --to=iec "$size")"

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_local

    printf "\n  ${GREEN}${B}✓ Sync complete${R}\n\n"
}

# ─── Status ───────────────────────────────────────────────────────────
read_spaces() {
    python3 -c "
import ctypes, json, struct, sys
lib = ctypes.CDLL('liblz4.so.1')
with open(sys.argv[1], 'rb') as f:
    data = f.read()
size = struct.unpack('<I', data[8:12])[0]
dst = ctypes.create_string_buffer(size)
lib.LZ4_decompress_safe(data[12:], dst, len(data)-12, size)
j = json.loads(dst.raw[:size])
print(f'{len(j[\"spaces\"])} spaces, {len(j[\"tabs\"])} tabs')
for s in sorted(j['spaces'], key=lambda x: x.get('position', 99999)):
    icon = s.get('icon', ' ')
    print(f'  {icon}  {s[\"name\"]}')
" "$1"
}

cmd_status() {
    load_config

    header "status"

    printf "  ${PURPLE}${B}LOCAL${R}\n"
    printf "  ${D}%s${R}\n" "$LOCAL_PROFILE"
    read_spaces "$LOCAL_PROFILE/zen-sessions.jsonlz4"

    printf "\n"

    if [[ "$MODE" == "ssh" ]]; then
        local remote="$REMOTE_USER@$REMOTE_HOST"
        printf "  ${PURPLE}${B}REMOTE${R} ${D}(%s)${R}\n" "$REMOTE_HOST"
        printf "  ${D}%s${R}\n" "$REMOTE_PROFILE"
        local tmp=$(mktemp)
        scp -q "$remote:$REMOTE_PROFILE/zen-sessions.jsonlz4" "$tmp" 2>/dev/null \
            && read_spaces "$tmp" \
            || fail "could not read remote sessions"
        rm -f "$tmp"
    else
        printf "  ${PURPLE}${B}REMOTE${R} ${D}(R2 cloud)${R}\n"
        local cloud_py
        cloud_py=$(find_py "cloud.py")
        local result
        result=$(python3 "$cloud_py" status "$(cloud_config_json)" 2>/dev/null) || { fail "could not read remote"; printf "\n"; return; }

        local error
        error=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('error',''))" 2>/dev/null)
        if [[ -n "$error" ]]; then
            fail "$error"
        else
            local ts hostname
            ts=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['timestamp'])")
            hostname=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['hostname'])")
            dim "  Last push: $ts from $hostname"

            # Download and read spaces
            local tmp_dir=$(mktemp -d)
            python3 "$cloud_py" pull "$(cloud_config_json | python3 -c "import sys,json; d=json.load(sys.stdin); d['profile']='$tmp_dir'; print(json.dumps(d))")" >/dev/null 2>&1
            [[ -f "$tmp_dir/zen-sessions.jsonlz4" ]] && read_spaces "$tmp_dir/zen-sessions.jsonlz4"
            rm -rf "$tmp_dir"
        fi
    fi

    printf "\n"
}

# ─── Merge ────────────────────────────────────────────────────────────
cmd_merge() {
    load_config
    local restart=false
    for arg in "$@"; do
        [[ "$arg" == "--restart" ]] && restart=true
    done

    header "merge"

    if [[ "$MODE" == "ssh" ]]; then
        local remote="$REMOTE_USER@$REMOTE_HOST"
        printf "  ${D}local${R} ${PURPLE}⇄${R} ${WHITE}${B}%s${R}\n\n" "$REMOTE_HOST"
    else
        printf "  ${D}local${R} ${PURPLE}⇄${R} ${WHITE}${B}R2 cloud${R}\n\n"
    fi

    [[ "$restart" == "true" ]] && zen_close_local

    # Download remote files to temp dir
    local tmp_dir=$(mktemp -d)

    if [[ "$MODE" == "ssh" ]]; then
        local remote="$REMOTE_USER@$REMOTE_HOST"
        step "  ↓" "Fetching remote sessions..."
        scp -q "$remote:$REMOTE_PROFILE/zen-sessions.jsonlz4" "$tmp_dir/zen-sessions.jsonlz4" 2>/dev/null \
            || die "could not download remote zen-sessions"
        scp -q "$remote:$REMOTE_PROFILE/sessionstore-backups/recovery.jsonlz4" "$tmp_dir/recovery.jsonlz4" 2>/dev/null || true
    else
        step "  ↓" "Downloading from R2..."
        local cloud_py
        cloud_py=$(find_py "cloud.py")
        python3 "$cloud_py" pull "$(cloud_config_json | python3 -c "import sys,json; d=json.load(sys.stdin); d['profile']='$tmp_dir'; print(json.dumps(d))")" >/dev/null \
            || die "could not download from R2"
        # Move recovery for merge.py
        [[ -f "$tmp_dir/sessionstore-backups/recovery.jsonlz4" ]] && \
            cp "$tmp_dir/sessionstore-backups/recovery.jsonlz4" "$tmp_dir/recovery.jsonlz4"
    fi
    ok "Remote files downloaded"

    # Run merge
    step "  ⇄" "Merging sessions..."
    local merge_py
    merge_py=$(find_py "merge.py")

    local result
    result=$(python3 "$merge_py" "$LOCAL_PROFILE" "$tmp_dir") || die "merge failed"

    local new_spaces new_tabs new_folders new_groups session_merged
    new_spaces=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['new_spaces'])")
    new_tabs=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['new_tabs'])")
    new_folders=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['new_folders'])")
    new_groups=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['new_groups'])")
    session_merged=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['session_merged'])")

    printf "\n"
    [[ "$new_spaces" -gt 0 ]] && ok "$new_spaces new spaces"
    [[ "$new_tabs" -gt 0 ]] && ok "$new_tabs new tabs"
    [[ "$new_folders" -gt 0 ]] && ok "$new_folders new folders"
    [[ "$new_groups" -gt 0 ]] && ok "$new_groups new groups"
    [[ "$session_merged" == "True" ]] && ok "Session store updated"

    if [[ "$new_spaces" -eq 0 && "$new_tabs" -eq 0 ]]; then
        dim "  Nothing new to merge"
    fi

    rm -rf "$tmp_dir"

    printf "\n"
    [[ "$restart" == "true" ]] && zen_open_local

    printf "\n  ${GREEN}${B}✓ Merge complete${R}\n\n"
}

# ─── Main ─────────────────────────────────────────────────────────────
case "${1:-help}" in
    push)   shift; cmd_push "$@" ;;
    pull)   shift; cmd_pull "$@" ;;
    merge)  shift; cmd_merge "$@" ;;
    status) cmd_status ;;
    init)   cmd_init ;;
    help|--help|-h) usage ;;
    *)      die "unknown command: $1. Run 'zen-sync help'" ;;
esac
